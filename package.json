{
  "name": "storefront_backend",
  "version": "0.1.0",
  "description": "",
  "main": "server.ts",
  "scripts": {
    "start": "node --env-file=.env src/server.ts",
    "watch": "tsc-watch --project tsconfig.json --esModuleInterop --onSuccess \"node --env-file=.env ./dist/server.js\"",
    "migrate:test-db": "dotenv -e .env.test -- db-migrate up -e test",
    "prepare:test-db": "dotenv -e .env.test -- node --loader ts-node/esm ./src/prepare-test-db.ts",
    "test": "npm run prepare:test-db && npm run migrate:test-db && dotenv -e .env.test -- node --loader ts-node/esm ./node_modules/jasmine/bin/jasmine.js --config=spec/support/jasmine.json",
    "tsc": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "author": "Ben Harrison",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.3.0",
    "db-migrate": "^1.0.0-beta.35",
    "db-migrate-pg": "^1.5.2",
    "express": "^5.2.1",
    "jasmine": "^6.3.0",
    "jasmine-spec-reporter": "^7.0.0",
    "pg": "^8.22.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node-lts": "^24.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "jiti": "^2.7.0",
    "prettier": "^3.9.4",
    "ts-node": "^10.9.2",
    "tsc-watch": "^7.2.0",
    "typescript-eslint": "^8.62.1"
  }
}
